# .env.example: committed template showing what environment variables the project expects, with safe dummy/default values
SECRET_KEY=replace-with-a-real-secret-key
FLASK_DEBUG=1
DATABASE_URL=
APP_TIMEZONE=Australia/Perth
DAILY_PROMPT_QUOTA=20
GROQ_API_KEY=
